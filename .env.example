# Flash Props API — environment
# Copy to .env and fill in. .env is gitignored.

# HTTP
PORT=3860
# Public base URL (used in OpenAPI servers + skill.md). No trailing slash.
PUBLIC_BASE_URL=http://localhost:3860

# SQLite database file
DATABASE_URL=./data/flash-props.sqlite

# Secret used to hash API keys (HMAC). Generate: openssl rand -hex 32
API_KEY_SECRET=dev-only-change-me-in-prod

# Data freshness for the free tier (ms of artificial delay/staleness). 0 = realtime.
FREE_TIER_DELAY_MS=300000

# Stripe (phase 2 — leave blank until wired)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
