# Flash Props API — environment
# Copy to .env and fill in. .env is gitignored.

# HTTP
PORT=3860
# Public base URL (used in OpenAPI servers + skill.md). No trailing slash.
PUBLIC_BASE_URL=http://localhost:3860

# SQLite database file
DATABASE_URL=./data/flash-props.sqlite

# Secret used to hash API keys (HMAC). Generate: openssl rand -hex 32
API_KEY_SECRET=dev-only-change-me-in-prod

# Data freshness for the free tier (ms of artificial delay/staleness). 0 = realtime.
FREE_TIER_DELAY_MS=300000

# Stripe (phase 2 — leave blank until wired)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=

# Crypto payments (Solana Pay, USDC). Crypto checkout enables only when
# RECEIVE_WALLET is set. Revenue lands there. Use a real RPC (Helius/QuickNode)
# in prod — the public endpoint is heavily rate-limited.
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
RECEIVE_WALLET=
USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
CRYPTO_DISCOUNT_PCT=10

# Base (EVM) USDC — enables when EVM_RECEIVE_WALLET is set. Use a real Base RPC in prod.
BASE_RPC_URL=https://mainnet.base.org
EVM_RECEIVE_WALLET=
USDC_BASE=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# Sale notifications — Discord webhook URL (or any endpoint accepting JSON). Pinged on each paid key.
NOTIFY_WEBHOOK=
